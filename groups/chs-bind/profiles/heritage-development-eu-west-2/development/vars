# Account details
aws_account = "heritage-development"
aws_region  = "eu-west-2"
environment = "development"
dns_zone_suffix = "heritage.aws.internal."
origin = "chs-bind-terraform"
vpc_name = "vpc-heritage-development"

# Instance details
instance_count = "2"
instance_type = "t3.medium"
root_volume_size = 30
service = "chs-bind"
service_subtype = "chs-bind"
application_subnet_pattern = "sub-application-*"
default_log_retention_in_days = "7"
monitoring = false
